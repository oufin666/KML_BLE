#include "beep.h"

void BEEP_Init(void)
{
    // TIM4 已经在 CubeMX 中配置为 PWM 模式
    // 这里只需要启动定时器
    HAL_TIM_PWM_Start(&htim4, TIM_CHANNEL_2);
    BEEP_Off();
}

void BEEP_SetVolume(uint8_t volume)
{
    if (volume > 100) volume = 100;
    
    uint16_t compare = (volume * 1000) / 100;
    __HAL_TIM_SET_COMPARE(&htim4, TIM_CHANNEL_2, compare);
}

void BEEP_On(void)
{
    BEEP_SetVolume(50); // 默认音量50%
}

void BEEP_Off(void)
{
    __HAL_TIM_SET_COMPARE(&htim4, TIM_CHANNEL_2, 0);
}